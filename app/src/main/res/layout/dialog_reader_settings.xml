<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surfaceColor">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reader_mode"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:layout_marginBottom="16dp" />

    <!-- Font Size -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reader_font_size"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnSizeSmall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="14"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnSizeMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="18"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnSizeLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="22"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnSizeXLarge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="26"
            style="?android:attr/buttonBarButtonStyle" />
    </LinearLayout>

    <!-- Font Family -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reader_font_family"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnFontSans"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_font_sans"
            android:typeface="sans"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnFontSerif"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_font_serif"
            android:typeface="serif"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btnFontMono"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_font_mono"
            android:typeface="monospace"
            style="?android:attr/buttonBarButtonStyle" />
    </LinearLayout>

    <!-- Background -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reader_background"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnBgWhite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_bg_white"
            android:backgroundTint="@color/white"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/btnBgSepia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_bg_sepia"
            android:layout_marginHorizontal="8dp"
            android:backgroundTint="@color/readerSepia"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/btnBgDark"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reader_bg_dark"
            android:backgroundTint="#121212"
            android:textColor="@color/white" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCloseReaderSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/popup_close"
        android:backgroundTint="@color/colorPrimary"
        android:textColor="@color/white" />

</LinearLayout>
